# Local development — loaded when NODE_ENV=development (see package.json scripts)
# Copy from ../.env.example if this file is missing.

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=hype_genius
DB_SYNC=false
DB_SSL=false
DB_POOL_MAX=10

PORT=5000
API_PREFIX=/api
BACKEND_DOMAIN=http://localhost:5000
FRONTEND_DOMAIN=http://localhost:3000

JWT_ACCESS_TOKEN_SECRET=dev-access-token-secret-change-me-min-32-chars-long
JWT_ACCESS_TOKEN_EXPIRES=1d
JWT_REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-me-min-32-chars
JWT_REFRESH_TOKEN_EXPIRES=365d
JWT_ONBOARDING_TOKEN_SECRET=dev-onboarding-token-secret-change-me-min-32
JWT_ONBOARDING_TOKEN_EXPIRES=1d

REDIS_URL=redis://127.0.0.1:6379
REDIS_EXPIRY=15
REDIS_PERMISSIONS_EXPIRY=31536000
