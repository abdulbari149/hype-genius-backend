# =============================================================================
# HypeGenius backend — environment variables
# =============================================================================
# Config is loaded from: env/<NODE_ENV>.env
#   - npm run start:dev / start → NODE_ENV=development → env/development.env
#   - production → env/production.env
#
# Copy this file to env/development.env (or env/production.env) and edit values.
# Do not commit real secrets; keep env/*.env out of version control if they contain secrets.
#
# Vercel: set the same keys in Project → Settings → Environment Variables.
# Vercel sets VERCEL=1 so .env files are not read; use the dashboard only.
# Supabase: Settings → Database → Connection string (Session mode for serverless).
#   Map host, port, user, password, database name into DB_* below. Use port 5432 or 6543 (pooler).
#   Set DB_SSL=true for remote Supabase.
# Upstash Redis: copy the full REDIS_URL (often rediss://... for TLS).
# =============================================================================

# --- PostgreSQL (TypeORM) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=hype_genius
# true = auto-sync schema (dev only); false for migrations / production
DB_SYNC=false
# Supabase / managed Postgres: set to true (required for TLS to Supabase host)
DB_SSL=false
# Smaller pool for serverless (e.g. Vercel); default 10 for local
DB_POOL_MAX=10

# --- HTTP API ---
PORT=5000
API_PREFIX=/api
# Public URLs (CORS uses FRONTEND_DOMAIN; use full origin, no trailing slash)
BACKEND_DOMAIN=http://localhost:5000
FRONTEND_DOMAIN=http://localhost:3000

# --- JWT ---
# Replace with long random strings in production (e.g. openssl rand -base64 32)
JWT_ACCESS_TOKEN_SECRET=replace-me-access-token-secret-min-32-characters
JWT_ACCESS_TOKEN_EXPIRES=1d
JWT_REFRESH_TOKEN_SECRET=replace-me-refresh-token-secret-min-32-characters
JWT_REFRESH_TOKEN_EXPIRES=365d
JWT_ONBOARDING_TOKEN_SECRET=replace-me-onboarding-token-secret-min-32-chars
JWT_ONBOARDING_TOKEN_EXPIRES=1d

# --- Redis (cache) ---
# Local: redis://127.0.0.1:6379
# Upstash: paste the Redis URL from the dashboard (often rediss:// for TLS)
REDIS_URL=redis://127.0.0.1:6379
# Generic cache TTL (seconds)
REDIS_EXPIRY=15
# Permissions cache TTL (seconds; e.g. 1 year)
REDIS_PERMISSIONS_EXPIRY=31536000
